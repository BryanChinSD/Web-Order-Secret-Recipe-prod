        function generatePickupAddress(method, handle) {
          let delivery_method = $('input[name="base_delivery_method"]:checked').val()
              cod = delivery_method == 'pickup_cod' ? '_cod' : '';

          if(method != "shipping"){
            $('#pickup-section, .delivery_method_sub-label').show()
            $('#pickup_address, #pickup_cod_address, #pickup_cod_instruction, #pickup_instruction, .pickup_title, .pickup_cod_title,.pickup_address, .pickup_app_label, .pickup_cod_app_label').hide()
            let address = null
            if (handle != undefined && handle != null) {
              address = _data.pickup_locations[handle]
              if (address == undefined) {
                address = _data.app_pickup_locations[handle]
              }
            }
            var pickup_address = ''
            if(method == "easystore" && handle != undefined && handle != null){
              $('#pickup'+cod+'_address, #pickup'+cod+'_address, .pickup_address, .receiver-section, .pickup'+cod+'_title, #pickup_datepicker').show()
              $('#pickup-app-address-wrapper').hide()
              if(address.address1 != undefined && address.address1 != null){
                pickup_address += address.address1+', '
              }
              if(address.address2 != undefined && address.address2 != null){
                pickup_address += address.address2+', '
              }
              if(address.city != undefined && address.city != null){
                pickup_address += address.city+', '
              }
              if(address.zip != undefined && address.zip != null){
                pickup_address += address.zip+', '
              }
              if(address.province != undefined && address.province != null){
                pickup_address += address.province+', '
              }
              if(address.country != undefined && address.country != null){
                pickup_address += address.country;
              }
              $('.pickup'+cod+'_title').text(address.title);
              $('.pickup'+cod+'_address').html(pickup_address);
              if(address.pickup_time_selection_enabled != true){
               $('.pickup'+cod+'_instruction').show();
               $('.pickup'+cod+'_instruction').text(address.pickup_description);
              }else{
               $('.pickup'+cod+'_instruction').hide();
              }

              let cod_min_max = true
              if (address.cod_min_amount > 0 || address.cod_max_amount > 0) {
                $(".cod_limit_section").show()
                if(address.cod_min_amount > 0 && address.cod_max_amount > 0){
                  $(".cod_limit_label").text("Cash on Delivery: ")
                }else{
                  $(".cod_limit_label").text("")
                  cod_min_max = false
                }
              }


              // Show / hide COD min limit
              if (address.cod_min_amount > 0) {
                let cod_min_label = cod_min_max ? "" : "Min. for Cash on Delivery: "
                $(".cod_minimum_limit").text(cod_min_label+' '+currencyFormat(address.cod_min_amount)).show()
              } else {
                $(".cod_minimum_limit").hide()
              }

              // Show / hide COD max limit
              if (address.cod_max_amount > 0) {
                let cod_max_label = cod_min_max ? " - " : "Max. for Cash on Delivery: "
                $(".cod_maximum_limit").text(cod_max_label+' '+currencyFormat(address.cod_max_amount)).show()
              } else {
                $(".cod_maximum_limit").hide()
              }

            } else {

              $('#pickup-section, #pickup_address, #pickup_cod_address, #pickup_datepicker, .cod_minimum_limit, #location-details-wrapper, #delivery-method-error, .pickup_address, #pickup_cod_instruction, #pickup_instruction').hide()
              $('#pickup'+cod+'_address, #pickup-app-address-wrapper, .receiver-section').show()
              if(address != null){
                $('.pickup'+cod+'_app_label').show()
                $('.pickup'+cod+'_title').show()
                $('.pickup'+cod+'_title').text(address.title);

               }

            }

          } else {
            $('#pickup-section, #pickup_address, #pickup_cod_address, #pickup_datepicker, .cod_minimum_limit, #location-details-wrapper, #delivery-method-error, .pickup_address, .receiver-section, .pickup_app_label, .pickup_cod_app_label, #pickup_cod_instruction, #pickup_instruction').hide()
            $('#pickup-app-address-wrapper').hide()
            $('.delivery_method_sub-label').hide()
          }
        }


