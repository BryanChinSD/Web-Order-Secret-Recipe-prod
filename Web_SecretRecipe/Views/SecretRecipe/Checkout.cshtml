                    <script type="text/javascript">
                        $( ".cart__remove" ).click(function() {

                          var unshippable_items = [];
                          var variant_ids       = [];
                          var quantities        = [];
                          var order_item_ids    = [];

                          for (i = 0; i < unshippable_items.length; i++) {
                            variant_ids.push(unshippable_items[i].variant_id);
                            quantities.push(unshippable_items[i].quantity)
                            order_item_ids.push(unshippable_items[i].id)
                          }

                          if ($(".shipping-option-item").length == 0) { // Add loading effect to whole section if no shipping methods is available
                            $('#shipping_methods .form-label-group, #shipping-methods-placeholder, #place-order').addClass('skeleton-loading')

                          } else { // Add loading effect after existing shipping method list
                            $("#app-shipping-loading").show()
                          }

                          $.ajax({
                            type: 'POST',
                            url: '/cart/remove_item_quantity',
                            data: {
                              variant_id: variant_ids,
                              quantity: quantities,
                              i_id: order_item_ids,
                            },
                            dataType: 'json',
                            success: function(response){
                              location.reload();
                            },
                            error: function(xhr){pickup_option
                              location.reload();
                            }
                          });

                        });

                    </script>
