                        <script>
              
                            var buttonId;
                            var netsMid;

                            // ─── Helpers ────────────────────────────────────────────────────────────────

                            function getTxnKey(suffix) {
                              var ref = localStorage.getItem("merchantTxnRef");
                              return ref ? "txn-" + ref + "-" + suffix : null;
                            }

                            function saveSelectionState() {
                              var ref = localStorage.getItem("merchantTxnRef");
                              if (!ref) return;
                              sessionStorage.setItem("txn-" + ref + "-buttonId", buttonId || "");
                              sessionStorage.setItem("txn-" + ref + "-netsMid", netsMid || "");
                            }

                            function restoreSelectionState() {
                              var ref = localStorage.getItem("merchantTxnRef");
                              if (!ref) return;
                              buttonId = sessionStorage.getItem("txn-" + ref + "-buttonId") || buttonId;
                              netsMid  = sessionStorage.getItem("txn-" + ref + "-netsMid")  || netsMid;

                              // Re-check the previously selected radio button
                              if (buttonId) {
                                var el = document.getElementById(buttonId);
                                if (el) el.checked = true;
                              }
                            }

                            // ─── Your original functions (unchanged) ────────────────────────────────────

                            function setRouteId(pRouteTo, pSelected, pSpecSvc) {
                              document.getElementById("routeTo").value = pRouteTo;
                              buttonId = pSpecSvc;
                              netsMid  = pSelected;
                              saveSelectionState(); // persist as soon as user makes a selection
                            }

                            function submitOnePager() {
                              var jsonStr        = document.getElementById("resp1JSON").value;
                              var routeTo        = document.getElementById("routeTo").value;
                              var selectedOption = document.getElementById(buttonId).value;
                              processServiceList(jsonStr, selectedOption, netsMid, routeTo);
                            }

                            function clearSelection() {
                              var ele = document.getElementById(buttonId);
                              if (ele) ele.checked = false;
                            }

                            function BanEnterKey() {
                              return window.event.keyCode !== 13;
                            }

                            function microsoftKeyPress() {
                              return window.event.keyCode === 13 ? checkFields() : false;
                            }

                            // ─── Save full form field values ─────────────────────────────────────────────

                            function saveFormState(form) {
                              var ref = localStorage.getItem("merchantTxnRef");
                              if (!ref || !form) return;

                              var formData = {};
                              form.querySelectorAll("input, select, textarea").forEach(function (el) {
                                if (!el.name) return;
                                if (el.type === "radio" || el.type === "checkbox") {
                                  formData[el.id || el.name] = el.checked;
                                } else {
                                  formData[el.name] = el.value;
                                }
                              });

                              sessionStorage.setItem("txn-" + ref + "-formState", JSON.stringify(formData));
                              sessionStorage.setItem("txn-" + ref + "-paymentLoaded", "true");
                              console.log("💾 Form state saved.");
                            }

                            // ─── Restore full form field values ──────────────────────────────────────────

                            function restoreFormState(form) {
                              var ref = localStorage.getItem("merchantTxnRef");
                              if (!ref || !form) return;

                              var raw = sessionStorage.getItem("txn-" + ref + "-formState");
                              if (!raw) return;

                              var formData = {};
                              try { formData = JSON.parse(raw); } catch (e) { return; }

                              form.querySelectorAll("input, select, textarea").forEach(function (el) {
                                var key = el.id || el.name;
                                if (key === undefined || !(key in formData)) return;

                                if (el.type === "radio" || el.type === "checkbox") {
                                  el.checked = formData[key];
                                } else {
                                  el.value = formData[key];
                                }
                              });

                              console.log("♻️ Form state restored.");
                            }

                            // ─── Core observer + submit logic ────────────────────────────────────────────

                            document.addEventListener("DOMContentLoaded", function () {
                              var ajaxTarget      = document.getElementById("ajaxResponse");
                              var merchantTxnRef  = localStorage.getItem("merchantTxnRef");

                              if (!ajaxTarget || !merchantTxnRef) {
                                console.warn("Missing #ajaxResponse or merchantTxnRef.");
                                return;
                              }

                              // ── If the user came BACK from the payment gateway, re-show the section ──
                              var wasLoaded = sessionStorage.getItem("txn-" + merchantTxnRef + "-paymentLoaded");
                              if (wasLoaded === "true") {
                                ajaxTarget.style.display = "block";   // make it visible again
                                restoreSelectionState();              // re-check the radio button
                                console.log("🔄 Payment section restored after back navigation.");
                              }

                              // ── Watch for the eNETS form being injected into #ajaxResponse ────────────
                              var observer = new MutationObserver(function () {
                                var form = ajaxTarget.querySelector("form");
                                if (!form || form.dataset.listenerAttached) return;

                                var warning = document.getElementById("paymentWarning");
                                if (warning) warning.style.display = "block";

                                console.log("✅ eNETS form detected. Attaching listeners.");

                                form.dataset.listenerAttached = "true";
                                console.log("✅ eNETS form detected. Attaching listeners.");

                                // Restore any previously saved field values into the form
                                restoreFormState(form);

                                // ── On submit: save state, notify backend, start fallback timer ─────────
                                form.addEventListener("submit", function () {
                                  console.log("🚀 Form submitting. Saving state & triggering fallback logic.");

                                  saveFormState(form);
                                  saveSelectionState();
                                  sessionStorage.setItem("txn-" + merchantTxnRef + "-submitted", "true");

                                  // Notify backend to start timeout window
                                  navigator.sendBeacon(
                                    "/SR/StartTxnTimeout",
                                    JSON.stringify({ merchantTxnRef: merchantTxnRef })
                                  );

                                  // Client-side safety net: query after 5 min if still unresolved
                                  setTimeout(async function () {
                                    var resolved = sessionStorage.getItem("txn-" + merchantTxnRef + "-resolved");
                                    if (resolved !== "true") {
                                      console.log("🕔 5 mins passed. Triggering TxnQuery...");
                                      await fetch(
                                        "/SR/QueryEnetsTxn?merchantTxnRef=" + encodeURIComponent(merchantTxnRef),
                                        { method: "POST" }
                                      );
                                    }
                                  }, 5 * 60 * 1000);
                                });
                              });

                              observer.observe(ajaxTarget, { childList: true, subtree: true });
                            });
                        </script>
