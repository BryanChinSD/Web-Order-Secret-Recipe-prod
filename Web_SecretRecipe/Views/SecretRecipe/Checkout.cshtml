        function attachEventListeners() {
            const pickupRadios = document.querySelectorAll('input[type="radio"][name="checkout[delivery_method]"]');
            pickupRadios.forEach(button => {
                button.removeEventListener('click', button._pickupClickHandler);
                const handler = (event) => handleRadioChange(event, true);
                button.addEventListener('click', handler);
                button._pickupClickHandler = handler;
            });

            const shippingRadios = document.querySelectorAll('input[name="base_delivery_method"][value="shipping"]');
            shippingRadios.forEach(button => {
                button.removeEventListener('change', button._shippingHandler);
                const handler = (event) => handleRadioChange(event, false);
                button.addEventListener('change', handler);
                button._shippingHandler = handler;
            });
        }

       function handleRadioChange(event, isPickup) {
        const button = event.target;

        // Your existing logic to update UI for delivery method
        updateUIForDeliveryMethod(isPickup, button.dataset.title, button.value);

        if (isPickup) {
            // Update operating hours display when a pickup outlet is selected
            const hours = button.dataset.operatingHours || "N/A";
            const outletName = button.dataset.title || "";
            document.getElementById("OperatingHours").innerHTML = `${hours}`;

            // Store the warehouseId on selection
            const warehouseId = button.dataset.warehouseId;
            if (warehouseId) {
                localStorage.setItem("warehouseId", warehouseId);
            }
        }

        // If you want to show modal only for pickup locations with specific values
        if (isPickup && button.value.startsWith('pickups-')) {
            showDeliveryModal();
        }
}



