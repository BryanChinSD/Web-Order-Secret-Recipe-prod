    <script>
        //////////////////////////////
        //                          //
        //        Shipping          //
        //                          //
        //////////////////////////////

        // Update shipping method preview
        function updateShippingPreview (shipping_handle = null, checkout = null){

        // console.log("updateShippingPreview", shipping_handle)

        // Get global selected shipping handle if not passed in
        if (shipping_handle == null && _data.selected_shipping_handle != undefined) {
          shipping_handle = _data.selected_shipping_handle
        }
        // console.log("shipping_handle", shipping_handle)

        if (shipping_handle != null) {
          previously_selected_shipping_method = $(document).find(".shipping-option-list-2").find("input[value='"+ shipping_handle +"']")

          // console.log("previously_selected_shipping_method", previously_selected_shipping_method)

          if (previously_selected_shipping_method.length > 0) { // Found previously selected method
            previously_selected_shipping_method.prop("checked", true)

            // Update media
            $('#shipping-price-info').hide()
            $('#shipping_methods #shipping-title').text(previously_selected_shipping_method.data("title"))
            if(previously_selected_shipping_method.data("price") > 0 && (checkout == null || previously_selected_shipping_method.data("price") > checkout.shipping_discount)){
              $('#shipping-price-info').show()
              $('#shipping_methods #shipping-price').text('Charge : '+currencyFormat(previously_selected_shipping_method.data("price")))
            }

            if (previously_selected_shipping_method.data("image") != null && previously_selected_shipping_method.data("image") != undefined && previously_selected_shipping_method.data("image") != "") {
              $('#shipping_methods #shipping-image_url').attr("src", previously_selected_shipping_method.data("image"))
              $('#shipping_methods #shipping-image_url').show()
            } else {
              $('#shipping_methods #shipping-image_url').hide()
            }

            $("#shipping-cod-rates").hide()
            if(_data.base_delivery_method == 'shipping_cod'){
              if(previously_selected_shipping_method.data("cod-min-amount") > 0){
                $("#shipping-cod-rates").text("Min. for Cash on Delivery: "+currencyFormat(previously_selected_shipping_method.data("cod-min-amount"))).show()
              }
              if(previously_selected_shipping_method.data("cod-max-amount") > 0){
                $("#shipping-cod-rates").text("Max. for Cash on Delivery: "+currencyFormat(previously_selected_shipping_method.data("cod-max-amount"))).show()
              }
              if(previously_selected_shipping_method.data("cod-min-amount") > 0 && previously_selected_shipping_method.data("cod-max-amount") > 0){
                $("#shipping-cod-rates").text("Cash on Delivery: "+currencyFormat(previously_selected_shipping_method.data("cod-min-amount"))+" - "+currencyFormat(previously_selected_shipping_method.data("cod-max-amount"))).show()
              }
            }

          } else { // Not found
            $(document).find("input[name='shipping_handle']").first().prop("checked", true)

            updateShippingPreview()
          }
        }

        }

       
    </script>
    <script>
        //////////////////////////////
        //                          //
        //         Payment          //
        //                          //
        //////////////////////////////

        // Update payment method preview
        function updatePaymentMedia(selected_handle){

          let selected_payment_method = null
          let payment_methods = _data.checkout.payment_methods

          for (var key in payment_methods) {
            if(payment_methods[key].hasOwnProperty('options')){
              var payment = payment_methods[key].options
            }
            else{
              var payment = payment_methods[key]
            }
            if(payment.length != undefined){
              for (var i in payment) {
                var payment_child = payment[i]
                if(payment_child.handle == selected_handle){
                  // fetchPaymentMedia(payment_child)
                  selected_payment_method = payment_child
                  break
                }
              }
            } else {
              if(payment.handle == selected_handle){
                // fetchPaymentMedia(payment)
                selected_payment_method = payment
                break
              }
            }
          }

          if (selected_payment_method != null) {
            let title = selected_payment_method.handle == "free" ? "Free" : selected_payment_method.title ,
                manual_qrpay = ["maybankqrpay","cimbpay","grabpay-qr","tngpay","favepay-qr","alipay","wechatpay","duitnow-qr","simple-pay"]

            $('#payment-title').text(title)
            $('#payment-charge-section').hide()
            $('#payment-charge_fee').text('')
            $('#payment-charge_rate').text('')


            if(selected_payment_method.transaction_charge_rate > 0){
              $('#payment-charge-section').show()
              $('#payment-charge_rate').text('Transaction Charge Rate: ' + selected_payment_method.transaction_charge_rate + '%')
            }

            if(selected_payment_method.transaction_charge_fee > 0){
              $('#payment-charge-section').show()
              $('#payment-charge_fee').text('Transaction Charge: ' + currencyFormat(selected_payment_method.transaction_charge_fee))
            }

            if(selected_payment_method.description != null && !manual_qrpay.includes(selected_payment_method.handle)){
              $('#payment-method-description').html(selected_payment_method.description);
              $('#payment-method-description').show();
            } else {
              $('#payment-method-description').html('');
              $('#payment-method-description').hide();
            }

          }

        }

        // To be deleted
        function fetchPaymentMedia(payment){
          $('#payment-title').text(payment.title)
          $('#payment-charge-section').hide()
          $('#payment-charge_fee').text('')
          $('#payment-charge_rate').text('')
          if(payment.transaction_charge_rate > 0){
            $('#payment-charge-section').show()
            $('#payment-charge_rate').text('Transaction Charge Rate: ' + payment.transaction_charge_rate + '%')
          }
          if(payment.transaction_charge_fee > 0){
            $('#payment-charge-section').show()
            $('#payment-charge_fee').text('Transaction Charge: ' + currencyFormat(payment.transaction_charge_fee))
          }
          if(payment.description != null){
            $('#payment-method-description').html(payment.description);
            $('#payment-method-description').show();
          }else{
            $('#payment-method-description').html('');
            $('#payment-method-description').hide();
          }
        }

        // To be deleted
        function savePaymentMethod(){
          _data.selected_payment_handle = $(document).find("[name='checkout[gateway_handle]']:checked").val()
          _data.selected_payment_category = $(document).find("[name='payment_category']:checked").val()
          $(document).find('.payment-input-label').text($(document).find('input[name="payment_category"]:checked').attr('data-title'));
          updatePaymentMedia(_data.selected_payment_handle)
          EasyStore.Checkout.api.updatePaymentMethod()
          $('#paymentModal').modal('hide')
        }

        function showPaymentMethod(){
          $(document).find('.collapse-payment-modal').hide();
          $(document).find('#paymentModalLabel').text($(document).find('input[name="payment_category"]:checked').attr('data-title'));
          setTimeout(function(){
            $(document).find('#collapse_payment_'+$('input[name="payment_category"]:checked').val()).show();
          },100);
        }

        $(document).on("click", "input[name='checkout[gateway_handle]'], #payment_modal_save", function(e){
          savePaymentMethod()
        });

        // On payment method dialog show
        $(document).on("show.bs.modal", '#paymentModal', function(e){
          _data.selected_payment_handle = $("input[name='checkout[gateway_handle]']:checked").val()
          showPaymentMethod();
        })

        // On payment method dialog hidden
        $(document).on("hidden.bs.modal", '#paymentModal', function(e){
          $(document).find("[name='payment_category'][value='"+_data.selected_payment_category+"']").prop( "checked", true )
        })



        // While changing payment category (eg: banking, card, offline etc)
        $(document).on("change", "input[name='payment_category']", function(e){
          showPaymentMethod();
        });

    </script>

