                    <script src="https://store-themes.easystore.co/896/themes/49034/assets/flatpickr.min.js?t=1740070810" type="text/javascript"></script>
                    <script>
                        let attr_form = document.querySelector('#customer-attr-form'),
                            attr_wrapper = document.querySelector('#customer-attr-wrapper'),
                            submit_button = document.querySelector('#submit-btn'),
                            error_content = document.querySelector('#error-content');
                        attr_form.addEventListener('submit', function (e) {
                          e.preventDefault();
                          error_content.innerHTML = '';
                          submit_button.classList.add('btn--loading');

                          let formData = new FormData(attr_form),
                              data = {};
                          formData.forEach((value, key) => {
                            const keys = key.split(/\[|\]/).filter(Boolean);

                            let current = data;
                            for (let i = 0; i < keys.length - 1; i++) {
                              const subKey = keys[i];
                              current[subKey] = current[subKey] || {};
                              current = current[subKey];
                            }

                            current[keys[keys.length - 1]] = value;
                          });

                          let jsonData = JSON.stringify(data);

                          fetch('/account/details', {
                            method: 'POST',
                            body: jsonData, // Convert object to JSON string
                            headers: {
                              'Content-Type': 'application/json',
                              'Accept': 'application/json'
                            }
                          })
                            .then(response => response.json())
                            .then(data => {
                              if (data.status === "success") {
                                attr_wrapper.innerHTML = `
                                  <div class="text-center">
                                    <svg fill="#13ce66" width="100px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M10.29 18.46a.59.59 0 0 0 .45-.21l8.71-9.63a.66.66 0 0 0 0-.92.65.65 0 0 0-.92 0l-8.27 9.14-4.82-4.32a.65.65 0 0 0-.88 1l5.29 4.81a.66.66 0 0 0 .44.13z"/><path d="M12 23.65A11.65 11.65 0 1 0 .35 12 11.67 11.67 0 0 0 12 23.65zm0-22A10.35 10.35 0 1 1 1.65 12 10.36 10.36 0 0 1 12 1.65z"/></svg>
                                    <h3>${data.message}</h3>
                                  </div>
                                `;
                              } else {
                                submit_button.classList.remove('btn--loading');
                                if (data.errors) {
                                  let errors = data.errors,
                                      error_html = `<div class="errors note">`;
                                    errors.forEach(msg => {error_html += `<div>${msg}</div>`})
                                  error_html += `</div>`;

                                  error_content.innerHTML = error_html;


                                }
                              }
                            })
                            .catch(error => {
                              submit_button.classList.remove('btn--loading');
                              if (error && error.message) error_content.innerHTML = `<div class="errors note">${error.message}</div>`;
                            });
                        });


                        flatpickr.localize({
                          weekdays: {
                              shorthand: ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"],
                              longhand: ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"],
                          },
                          months: {
                              shorthand: ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"],
                              longhand: ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"],
                          }
                        })

                        let input_birthdate = flatpickr("#DetailBirthdate",{
                          maxDate: "today",
                          disableMobile: "true",
                          allowInput:true,
                          onOpen: function(selectedDates, dateStr, instance) {
                              document.querySelector("#DetailBirthdate").setAttribute('readonly', true);
                          },
                          onClose: function(selectedDates, dateStr, instance) {
                              document.querySelector("#DetailBirthdate").removeAttribute('readonly');
                              document.querySelector("#DetailBirthdate").blur();
                          }
                        });

                        flatpickr(".input-datepicker",{
                          disableMobile: "true",
                          allowInput:true
                        });

                        var customer_attributes = [];
                        var attribute_settings = "";
                        if(typeof customer_attributes == 'object' && typeof attribute_settings == 'object'){
                          attribute_settings.forEach(function (attribute_setting) {
                            customer_attributes.forEach(function (customer_attribute) {
                              if(customer_attribute.customer_attribute_setting_id == attribute_setting.id) {
                                document.querySelector('#DetailAttribute' + attribute_setting.id).value = customer_attribute.value;
                              }
                            });
                          });
                        }
                    </script>



