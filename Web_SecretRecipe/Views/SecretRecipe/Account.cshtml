        const overlay = document.querySelector('.modal-overlay');
        const mainContainer = document.querySelector('#maincontent');
        const footer = document.querySelector('.footer.color-background-1');
        const closeButton = document.querySelector('.search-modal__close-button');
        var detailsElement = document.getElementById("myDetails");

        // Ensure modal and overlay are hidden by default
        hideElement(modal);
        hideElement(overlay);

        // Add event listener for opening the modal
        attachClickListener(openButtonIcon, function () {
            toggleModal(true); // Open the modal
        });

        // Add event listeners for closing the modal
        attachClickListener(closeButton, function () {
            toggleModal(false); // Close the modal
            // Remove the 'open' attribute from the <details> element
            detailsElement.removeAttribute("open");
