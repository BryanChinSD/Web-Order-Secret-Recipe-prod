            <ul style="flex-grow: 2; margin: 0px;">
                <li id="announcement_bar_0" style="display: flex; justify-content: center; align-items: center; flex-wrap: wrap; margin: 0px; width: 100%; word-wrap: break-word; color : white;">
                   
                </li>
            </ul>
            <div style="display: flex;">
