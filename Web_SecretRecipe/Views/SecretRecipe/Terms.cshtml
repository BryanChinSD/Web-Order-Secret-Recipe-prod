    <script>
               // Utility function to show elements
        function showElement(element) {
            if (element) {
                element.style.display = 'block';
            }
        }

        // Utility function to hide elements
        function hideElement(element) {
            if (element) {
                element.style.display = 'none';
            }
        }

        // Utility function to toggle modal state
        function toggleModal(isOpen) {
            if (isOpen) {
                showElement(modal);
                showElement(overlay);
                // hideElement(mainContainer);
                // hideElement(footer);
            } else {
                hideElement(modal);
                hideElement(overlay);
                showElement(mainContainer);
                showElement(footer);
            }
        }

        // Ensure event listeners are attached properly
        function attachClickListener(element, callback) {
            if (element) {
                element.addEventListener('click', callback);
            }
        }

        // Get elements using document
        const openButtonIcon = document.querySelector('#icon-searchbtn'); // Button for opening the modal
        const closeButtonIcon = document.querySelector('.modal__close-button .icon');
        const modal = document.querySelector('#search_modal');
        const overlay = document.querySelector('.modal-overlay');
        const mainContainer = document.querySelector('#maincontent');
        const footer = document.querySelector('.footer.color-background-1');
        const closeButton = document.querySelector('.search-modal__close-button');
        var detailsElement = document.getElementById("myDetails");

        // Ensure modal and overlay are hidden by default
        hideElement(modal);
        hideElement(overlay);

        // Add event listener for opening the modal
        attachClickListener(openButtonIcon, function () {
            toggleModal(true); // Open the modal
        });

        // Add event listeners for closing the modal
        attachClickListener(closeButton, function () {
            toggleModal(false); // Close the modal
            // Remove the 'open' attribute from the <details> element
            detailsElement.removeAttribute("open");
            console.log("Modal closed and details removed");
        });

        attachClickListener(closeButtonIcon, function () {
            toggleModal(false); // Close the modal
            // Remove the 'open' attribute from the <details> element
            detailsElement.removeAttribute("open");
            console.log("Modal closed and details removed");
        });

        // Add event listener to close the modal when the overlay is clicked
        attachClickListener(overlay, function () {
            toggleModal(false); // Close the modal
            // Remove the 'open' attribute from the <details> element
            detailsElement.removeAttribute("open");
            console.log("Modal closed and details removed");
        });
    </script>

