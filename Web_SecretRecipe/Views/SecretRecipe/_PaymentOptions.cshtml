@model Web_SecretRecipe.Models.PaymentOptionsViewModel

<div class="payment-methods grid grid-cols-2 gap-4 mt-4">
    @foreach (var option in Model.Options)
    {
        <div class="border rounded p-4 flex items-center gap-2 shadow hover:shadow-md transition cursor-pointer">
            <img src="@option.IconUrl" alt="@option.Name" class="w-8 h-8" />
            <span>@option.Name</span>
        </div>
    }
</div>
