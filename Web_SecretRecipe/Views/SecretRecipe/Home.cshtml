           document.addEventListener("DOMContentLoaded", function () {
            const carousel = $('#mainCarousel');
            const prevControl = $('.carousel-control-prev');
            const nextControl = $('.carousel-control-next');

            // Set fast transition speed for user interaction
            const fastInterval = 200; // 200ms for faster slide speed

            // Function to adjust the transition
            function setCarouselSpeed(speed) {
                carousel.carousel('dispose'); // Dispose of the current instance
                carousel.carousel({ interval: speed }); // Set a new instance with the desired speed
            }

            // Handle prev button click
            prevControl.on('click', function (e) {
                e.preventDefault();
                setCarouselSpeed(fastInterval); // Set faster speed
                carousel.carousel('prev'); // Move to the previous slide
            });

            // Handle next button click
            nextControl.on('click', function (e) {
                e.preventDefault();
                setCarouselSpeed(fastInterval); // Set faster speed
                carousel.carousel('next'); // Move to the next slide
            });

            // // Reset speed to default after the transition is complete
            // carousel.on('slid.bs.carousel', function () {
            //     setCarouselSpeed(5000); // Reset to default auto-slide speed (e.g., 5 seconds)
            // });
        });
        document.addEventListener("DOMContentLoaded", function () {
            const slider = document.querySelector(".slider-unique");
            const slides = document.querySelectorAll(".slide-unique");
            const dots = document.querySelectorAll(".slider-dot-unique");

            if (!slider || slides.length === 0) return; // safeguard

            let currentSlide = 0;
            let isTransitioning = false;
            let autoSlide;

            function updateSlider() {
                slider.style.transform = `translateX(-${currentSlide * 100}%)`;
                dots.forEach((dot, index) => {
                    dot.classList.toggle("active", index === currentSlide);
                });
            }

            function nextSlide() {
                if (isTransitioning) return;
                isTransitioning = true;

                currentSlide = (currentSlide + 1) % slides.length;
                updateSlider();

                setTimeout(() => {
                    isTransitioning = false;
                }, 500); // matches CSS transition duration
            }

            function prevSlide() {
                if (isTransitioning) return;
                isTransitioning = true;

                currentSlide = (currentSlide - 1 + slides.length) % slides.length;
                updateSlider();

                setTimeout(() => {
                    isTransitioning = false;
                }, 500);
            }

            // restart auto-slide whenever user interacts
            function resetAutoSlide() {
                clearInterval(autoSlide);
                autoSlide = setInterval(nextSlide, 5000);
            }

            // Dot navigation
            dots.forEach((dot, index) => {
                dot.addEventListener("click", () => {
                    currentSlide = index;
                    updateSlider();
                    resetAutoSlide(); // 🔥 restart auto-slide
                });
            });

            // Start auto-slide
            autoSlide = setInterval(nextSlide, 5000);

            // Initialize
            updateSlider();
        });


        window.addEventListener('DOMContentLoaded', () => {
          const slider = document.querySelector('.carousel-slide');
          if (slider) {
            const observer = new MutationObserver(() => {
              slider.style.transition = 'none';
              slider.style.transform = 'translateX(0%)';
            });

            observer.observe(slider, { attributes: true, attributeFilter: ['style'] });
          }
        });



        document.addEventListener('DOMContentLoaded', function() {
            const slider = document.querySelector('.slider');
            const slides = document.querySelectorAll('.slide');
            const dots = document.querySelectorAll('.slider-dot');
            // const prevBtn = document.getElementById('prev-btn');
            // const nextBtn = document.getElementById('next-btn');
            const currentSlideIndicator = document.getElementById('current-slide');
            // const translateValue = document.getElementById('translate-value');

            let currentSlideIndex = 0;
            let autoSlideInterval;

            // Function to update slider position
            function updateSlider() {
                const translateXValue = -currentSlideIndex * 100;
                slider.style.transform = `translateX(${translateXValue}%)`;
                // translateValue.textContent = `${translateXValue}%`;

                // Update dots
                dots.forEach((dot, index) => {
                    if (index === currentSlideIndex) {
                        dot.classList.add('active');
                    } else {
                        dot.classList.remove('active');
                    }
                });


            }

            // Next slide function with constraint
            function nextSlide() {
                if (currentSlideIndex < slides.length - 1) {
                    currentSlideIndex++;
                    updateSlider();
                }
            }

            // Previous slide function with constraint
            function prevSlide() {
                if (currentSlideIndex > 0) {
                    currentSlideIndex--;
                    updateSlider();
                }
            }

            // Start auto slide
            function startAutoSlide() {
                autoSlideInterval = setInterval(() => {
                    if (currentSlideIndex < slides.length - 1) {
                        nextSlide();
                    } else {
                        // Stop auto sliding when reaching the end
                        clearInterval(autoSlideInterval);
                    }
                }, 3000);
            }

            // Stop auto slide
            function stopAutoSlide() {
                clearInterval(autoSlideInterval);
            }

            // Add event listeners to dots
            dots.forEach((dot, index) => {
                dot.addEventListener('click', () => {
                    stopAutoSlide();
                    currentSlideIndex = index;
                    updateSlider();
                    startAutoSlide();
                });
            });

      

            // Pause on hover
            const sliderContainer = document.querySelector('.mobile-slider');
            sliderContainer.addEventListener('mouseenter', stopAutoSlide);
            sliderContainer.addEventListener('mouseleave', startAutoSlide);

            // Swipe functionality for touch devices
            let touchStartX = 0;
            let touchEndX = 0;
            let touchStartY = 0;
            let touchEndY = 0;

            slider.addEventListener('touchstart', function(e) {
                touchStartX = e.changedTouches[0].screenX;
                touchStartY = e.changedTouches[0].screenY;
                stopAutoSlide();
            });

            slider.addEventListener('touchend', function(e) {
                touchEndX = e.changedTouches[0].screenX;
                touchEndY = e.changedTouches[0].screenY;
                handleSwipe();
                startAutoSlide();
            });

            function handleSwipe() {
                const deltaX = touchEndX - touchStartX;
                const deltaY = touchEndY - touchStartY;

                // Only trigger swipe if horizontal movement is greater than vertical
                if (Math.abs(deltaX) > Math.abs(deltaY)) {
                    if (deltaX < -50) {
                        // Swipe left - next slide
                        nextSlide();
                    } else if (deltaX > 50) {
                        // Swipe right - previous slide
                        prevSlide();
                    }
                }
            }

            // Initialize the slider
            updateSlider();
            // startAutoSlide();
        });


    </script>
