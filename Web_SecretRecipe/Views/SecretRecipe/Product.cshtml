        function toggleFAQ(element) {
            let answer = element.nextElementSibling;
            let icon = element.querySelector('.icon');
            if (answer.style.display === "block") {
                answer.style.display = "none";
                icon.textContent = "+";
                icon.classList.remove("rotate");
            } else {
                answer.style.display = "block";
                icon.textContent = "-";
                icon.classList.add("rotate");
            }
        }


        document.addEventListener("DOMContentLoaded", () => {
            if (typeof Splide === 'undefined') {
                console.error("Splide is not loaded.");
                return;
            }

            const slider = new Splide('#ProductPhoto').mount();
            const mainImage = document.getElementById('zmimage');
            const previewImages = Array.from(document.querySelectorAll('.preview-image'));

            let upcomingIndex = 0;

            slider.on('move', (newIndex) => {
                upcomingIndex = newIndex;
            });

            slider.on('moved', () => {
                if (previewImages[upcomingIndex]) {
                    mainImage.src = previewImages[upcomingIndex].src;
                    updateActivePreviews(upcomingIndex);
                }
            });

            previewImages.forEach((img, i) => {
                img.addEventListener('click', () => {
                    slider.go(i);
                });
            });

            function updateActivePreviews(index) {
                previewImages.forEach((img, i) => {
                    img.classList.toggle('active-preview', i === index);
                });
            }
        });

        const input = document.getElementById('cake-writing');
        const counter = document.getElementById('char-count');

