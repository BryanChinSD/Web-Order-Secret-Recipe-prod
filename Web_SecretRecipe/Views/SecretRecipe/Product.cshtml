        document.addEventListener('DOMContentLoaded', function () {
            const STORAGE_KEY = "type";

            function syncRadioButtonsWithSession() {
              const radioButtons = document.querySelectorAll('input[name="Size"]');

              if (radioButtons.length === 0) return;

              const storedValue = sessionStorage.getItem(STORAGE_KEY);
              let defaultSet = false;

              radioButtons.forEach((radio, index) => {
                if (storedValue && radio.value === storedValue) {
                  radio.checked = true;
                  defaultSet = true;
                  console.log(`${storedValue} selected from sessionStorage`);
                }
              });

              if (!defaultSet) {
                radioButtons[0].checked = true;
                sessionStorage.setItem(STORAGE_KEY, radioButtons[0].value);
                sessionStorage.setItem("typeID", radioButtons[0].id);
                console.log(`${radioButtons[0].value} set as default and saved`);
              }
            }

            // Use event delegation for dynamic content
            document.addEventListener("change", function (e) {
              if (e.target && e.target.matches('input[name="Size"]')) {
                if (e.target.checked) {
                  sessionStorage.setItem("type", e.target.value);
                  sessionStorage.setItem("typeID", e.target.id);
                  console.log(`${e.target.value} saved to sessionStorage`);
                }
              }
            });

            // Wait for dynamic content, then apply
            setTimeout(syncRadioButtonsWithSession, 300);
          });

