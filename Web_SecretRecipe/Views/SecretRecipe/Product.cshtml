                this.mainDetailsToggle.addEventListener('mouseover', this.open.bind(this));
                this.mainDetailsToggle.addEventListener('mouseleave', this.close.bind(this));
            }

            onFocusOut() {
                setTimeout(() => {
                    if (!this.contains(document.activeElement)) this.close();
