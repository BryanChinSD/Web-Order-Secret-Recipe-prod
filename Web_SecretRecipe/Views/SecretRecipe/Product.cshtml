           const tabLinks = document.querySelectorAll(".prod-desc-tab .tablinks");
           const tabContents = document.querySelectorAll(".prod-desc-tab-content");
           const tabHeadings = document.querySelectorAll(".tab_drawer_heading");

           tabLinks.forEach((tabLink) => {
             tabLink.addEventListener("click", function () {
               // Remove the 'active' class from all tabs
               tabLinks.forEach((tab) => tab.classList.remove("active"));

               // Add the 'active' class to the clicked tab
