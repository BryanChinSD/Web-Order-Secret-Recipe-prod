        function setupQuantityAdjuster(containerSelector) {
            const containers = document.querySelectorAll(containerSelector);

            containers.forEach((container) => {
                const input = container.querySelector("input[type='number']");
                const buttons = container.querySelectorAll("[data-adjust]");
      
                if (!input || buttons.length === 0) return; // Skip if no input or buttons found

                // Add event listeners to the buttons
                buttons.forEach((button) => {
                    button.addEventListener("click", () => {
                        const isIncrement = button.getAttribute("data-adjust") === "1";
                        const currentValue = parseInt(input.value, 10) || 1;
                        const maxValue = parseInt(input.max, 10) || Infinity;
                        const minValue = parseInt(input.min, 10) || 1;

                        if (isIncrement) {
                            // Increment logic
                            if (currentValue < maxValue) {
                                input.value = currentValue + 1;
                       

                            }
                        } else {
                            // Decrement logic
                            if (currentValue > minValue) {
                                input.value = currentValue - 1;
               
                            }
                        }
                    });
                });
            });
        }

