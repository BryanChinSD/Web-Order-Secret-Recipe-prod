        function setActiveTab(clickedTab, sectionId) {
          // Remove active class from all tabs
          const tabs = document.querySelectorAll('#menuTabs .tab-item');
          tabs.forEach(tab => tab.classList.remove('active', 'text-black', 'border-b-2', 'border-red-500'));

          // Hide all tab contents
          const contents = document.querySelectorAll('.tab-content');
          contents.forEach(content => content.classList.add('hidden'));

          // Activate the clicked tab and show the corresponding content
          clickedTab.classList.add('active', 'text-black', 'border-b-2', 'border-red-500');
          document.getElementById(sectionId).classList.remove('hidden');
